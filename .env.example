# ──────────────────────────────────────
# Supabase Edge Function Secrets
# Set via: supabase secrets set KEY=VALUE
# ──────────────────────────────────────

ENV_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
ENV_SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# SMTP (GoDaddy or any SMTP server)
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=your-email-password
SMTP_FROM="Muscle Box Pro <your-email@yourdomain.com>"

# CC addresses for form submissions
DEMO_REQUEST_CC=contact@muscleboxpro.com
CAMPAIGN_REQUEST_CC=contact@muscleboxpro.com
CONTACT_REQUEST_CC=contact@muscleboxpro.com
