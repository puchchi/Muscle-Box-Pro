PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5000
# Optional comma-separated allowlist for extra frontend origins
# Example: FRONTEND_URLS=http://localhost:5001,http://127.0.0.1:5000
FRONTEND_URLS=
# Public backend URL used in verification links
BACKEND_PUBLIC_URL=http://localhost:5001

# Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Public key for auth flows handled by backend
SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional, keep server-only. Never expose this to client code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase JWT audience usually remains "authenticated"
SUPABASE_JWT_AUDIENCE=authenticated

# Existing Postgres integration (if used with Drizzle)
DATABASE_URL=postgresql://postgres:password@db.host:5432/postgres

# Custom email verification settings
EMAIL_VERIFICATION_SECRET=replace-with-a-long-random-secret
EMAIL_VERIFICATION_TTL_MINUTES=60
PASSWORD_RESET_SECRET=replace-with-a-different-long-random-secret
PASSWORD_RESET_TTL_MINUTES=30
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="Muscle Box Pro <no-reply@muscleboxpro.com>"
DEMO_REQUEST_CC=contact@muscleboxpro.com
CAMPAIGN_REQUEST_CC=contact@muscleboxpro.com
